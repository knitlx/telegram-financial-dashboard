    "lint": "BROWSERSLIST_IGNORE_OLD_DATA=1 eslint"
  },
  "dependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/pg": "^8.15.6",
    "crypto-js": "^4.2.0",
    "next": "16.0.10",
    "pg": "^8.16.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "recharts": "^3.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.21",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
